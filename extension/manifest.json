{
  "manifest_version": 3,
  "name": "Simple Password Manager",
  "version": "1.0.0",
  "description": "Master login in the popup, XOR-encrypted saved logins in chrome.storage.",
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Password Manager"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
